# ReplyFlow Meta / Instagram connector
#
# Copy this file to .env.local and fill in real values.
# Never commit real tokens or secrets.

# Any random secret phrase you also enter into Meta's webhook verification screen.
META_VERIFY_TOKEN=replace_with_a_private_verify_token

# Meta App Secret. Used to verify x-hub-signature-256 webhook requests.
META_APP_SECRET=replace_with_meta_app_secret

# Page access token with Instagram messaging permissions.
META_PAGE_ACCESS_TOKEN=replace_with_page_access_token

# Optional. Defaults to v21.0 when omitted.
META_GRAPH_API_VERSION=v21.0

# Keep false while testing. Set true only when you want ReplyFlow to send real IG messages.
REPLYFLOW_AUTO_SEND=false
